# Example environment variables for DoctorsCares
# Copy this file to .env and fill in your own values.

PORT=5000
SESSION_SECRET=your-session-secret-here
# Standard (no SRV) — use if mongodb+srv fails with querySrv ECONNREFUSED
MONGODB_URI=mongodb://<username>:<password>@<shard-00-00>.mongodb.net:27017,<shard-00-01>.mongodb.net:27017,<shard-00-02>.mongodb.net:27017/<database>?ssl=true&authSource=admin&replicaSet=<replica-set-name>&retryWrites=true&w=majority

# Default admin (created once on first startup if missing)
ADMIN_EMAIL=admin@doctorscares.eg
ADMIN_PASSWORD=admin123
ADMIN_NAME=Super Admin
